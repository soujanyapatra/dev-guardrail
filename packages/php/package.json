{
  "name": "@devguard/php",
  "version": "0.1.0",
  "description": "PHP plugin for DevGuard - Laravel, Symfony, WordPress support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "devguard",
    "php",
    "laravel",
    "symfony",
    "wordpress",
    "quality",
    "security"
  ],
  "author": "DevGuard Contributors",
  "license": "MIT",
  "peerDependencies": {
    "@devguard/core": "^0.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
